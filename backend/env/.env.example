# 환경 변수 예시 파일
# 실제 사용 시 이 파일을 복사하여 .env.development, .env.production 파일을 만드세요

# 환경 설정
NODE_ENV=development

# 서버 포트
PORT=5001

# PostgreSQL 연결 URL
DATABASE_URL="postgresql://username:password@localhost:5432/prisma_auth"

# JWT 비밀키 
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# 백엔드/프론트엔드 URL
API_BASE_URL="http://localhost:5001"
CLIENT_BASE_URL="http://localhost:3000"

# OAuth (Google / Kakao / Naver)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
